        "key_focus": "Execution",
        "challenges": [
          {
            "title": "Premium vs Freemium (Stratascratch ID 10300)",
            "difficulty": "Hard",
            "type": "sql",
            "question": "Find the total number of downloads for paying and non-paying users by date. Include only records where non-paying customers have more downloads than paying customers. The output should be sorted by earliest date first and contain 3 columns: date, non-paying downloads, paying downloads.",
            "tables": [
              "ms_user_dimension",
              "ms_acc_dimension",
              "ms_download_facts"
            ],
            "initial_code": "SELECT * FROM ms_download_facts LIMIT 5;",
            "solution": "\nWITH joined AS (\n    SELECT \n        d.date,\n        d.downloads,\n        a.paying_customer\n    FROM ms_download_facts d\n    JOIN ms_user_dimension u ON d.user_id = u.user_id\n    JOIN ms_acc_dimension a ON u.acc_id = a.acc_id\n)\nSELECT \n    date,\n    SUM(CASE WHEN paying_customer = 'no' THEN downloads ELSE 0 END) as non_paying,\n    SUM(CASE WHEN paying_customer = 'yes' THEN downloads ELSE 0 END) as paying\nFROM joined\nGROUP BY date\nHAVING SUM(CASE WHEN paying_customer = 'no' THEN downloads ELSE 0 END) > SUM(CASE WHEN paying_customer = 'yes' THEN downloads ELSE 0 END)\nORDER BY date\n"
          }
        ],
        "question_type": "code_challenges"
      },
      {
        "step": 3,
        "name": "Onsite Loop",
        "duration": "4 hrs",
        "description": "Multiple rounds.",
        "key_focus": "Depth",
        "practice_question": "Tell me about a complex project.",
        "question_type": "text"
      }
